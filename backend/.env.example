PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3307
DB_USER=chatapp
DB_PASSWORD=chatapp
DB_NAME=chatapp

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

LLM_PROVIDER=azure-openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

AZURE_OPENAI_ENDPOINT=
