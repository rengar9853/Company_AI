PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3307
DB_USER=chatapp
DB_PASSWORD=chatapp
DB_NAME=chatapp

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Only needed if you still want the website itself to call a model directly.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_AUTH_SCOPE=https://cognitiveservices.azure.com/.default
AZURE_OPENAI_AUTH_TOKEN=
AZURE_OPENAI_ENABLE_WEB_SEARCH=false
AZURE_OPENAI_WEB_SEARCH_TOOL_TYPE=web_search_preview
AZURE_OPENAI_REALTIME_MODEL=
AZURE_OPENAI_REALTIME_REGION=

# DefaultAzureCredential can read these when using service principal auth.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

MCP_SERVER_NAME=company-ai-mcp
MCP_SERVER_VERSION=0.3.0
MCP_BEARER_TOKEN=

UPLOAD_DIR=../data/uploads
MAX_UPLOAD_MB=200

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


